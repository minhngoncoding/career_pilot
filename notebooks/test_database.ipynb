# %%
from career_pilot.core.database import get_client, get_collection

# %%
client = get_client()
print(f"Client: {client}")
collection = get_collection("test")
print(f"Collection: {collection}")
collection.add(documents=["Test"], ids=["t1"], metadatas=[{"type": "test"}])
print("Added")
results = collection.query(query_texts=["Test"], n_results=1)
print(f"Results: {results}")
collection.delete(ids=["t1"])
print("Deleted")

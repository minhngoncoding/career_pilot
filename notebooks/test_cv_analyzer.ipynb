# %% [markdown]
# # Test CV Analyzer
#
# Testing the CV analyzer with user request consideration

# %%
import sys
sys.path.insert(0, 'src')

from career_pilot.agents.cv_analyzer import CVAnalyzer
from career_pilot.tools.cv_parser import parse_resume

# %% [markdown]
# ## Test 1: Analyze CV from file

# %%
cv_analyzer = CVAnalyzer()

# Test with a sample CV text (no file)
cv_text = """
John Doe
Email: john.doe@email.com
Phone: (555) 123-4567

EXPERIENCE
Senior Software Engineer at Tech Corp (2020-Present)
- Led development of microservices architecture
- Improved system performance by 40%
- Mentored 5 junior developers

Software Engineer at StartupXYZ (2018-2020)
- Built REST APIs using Python and Flask
- Implemented authentication system

SKILLS
Python, JavaScript, Docker, AWS, PostgreSQL, Redis"""

user_request = "Analyze my CV for senior Python role"

result = cv_analyzer.analyze_cv(cv_text=cv_text, user_request=user_request)
print(result)

# %% [markdown]
# ## Test 2: Analyze with specific target

# %%
user_request = "Check if my CV is good for Google"
result = cv_analyzer.analyze_cv(cv_text=cv_text, user_request=user_request)
print(result)

# %% [markdown]
# ## Test 3: Analyze with multiple requests

# %%
user_requests = [
    "Analyze my CV",
    "What can you improve on my CV for a backend position?",
    "Check if my CV is suitable for a senior developer role at FAANG company",
    "Rate my CV and suggest improvements for tech lead position"
]

for req in user_requests:
    print(f"\n{'='*50}")
    print(f"Request: {req}")
    print('='*50)
    result = cv_analyzer.analyze_cv(cv_text=cv_text, user_request=req)
    print(result[:500] if len(result) > 500 else result)

